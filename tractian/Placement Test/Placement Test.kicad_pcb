	(gr_text_box "Control and analog components isolated from the high current paths to prevent noise."
		(start 33 75.34)
		(end 60.9 81.34)
		(margins 1.0025 1.0025 1.0025 1.0025)
		(layer "Cmts.User")
		(uuid "2b433bcb-4c07-413b-8722-083775d83dd6")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify left top)
		)
		(border yes)
		(stroke
			(width 0.15)
			(type solid)
		)
	)
	(gr_text_box "Hot loop optmization with the compact placement of transistors and capacitors to minimize EMI during the high amperage, high frequency switching."
		(start 29.65 26.94)
		(end 66.95 34.54)
		(margins 1.0025 1.0025 1.0025 1.0025)
		(layer "Cmts.User")
		(uuid "83a557df-07af-4dff-a1f4-618c922ee478")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify left top)
		)
		(border yes)
		(stroke
			(width 0.15)
			(type solid)
		)
	)
	(gr_text_box "Extensive use of copper pours for power signals to ensure low resistance and thermal stability under 20A loads."
		(start 82.8 28.09)
		(end 115.9 34.99)
		(margins 1.0025 1.0025 1.0025 1.0025)
		(layer "Cmts.User")
		(uuid "a6626161-5739-41bd-b034-92765a9095c2")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify left top)
		)
		(border yes)
		(stroke
			(width 0.15)
			(type solid)
		)
	)
	(gr_text_box "4 layer layout, with GND and VCC planes to ensure low impedance paths for the return currents and to improve the shielding.\nVias were used to equalize potential across all planes and surfaces, while serving as heatsink as well."
		(start 82.55 75.14)
		(end 120.15 86.34)
		(margins 1.0025 1.0025 1.0025 1.0025)
		(layer "Cmts.User")
		(uuid "ff5fd701-060e-4180-8afb-46ba58d09fcb")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify left top)
		)
		(border yes)
		(stroke
			(width 0.15)
			(type solid)
		)
	)
